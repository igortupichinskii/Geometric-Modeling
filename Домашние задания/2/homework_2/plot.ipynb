    "from cv2 import log\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "n = np.array([16, 64, 256])\n",
    "t = np.array([0.202880859375, 0.72412109375, 1.349609375])\n",
    "\n",
    "plt.plot(n, t)\n",
    "# plt.yscale('log')\n",
    "plt.xscale('log')\n",
    "plt.xlabel('n')\n",
    "plt.ylabel('t')\n",
    "plt.title('$t(n)$')"
